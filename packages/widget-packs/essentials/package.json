{
  "name": "@promptkit/widget-pack-essentials",
  "version": "0.1.0",
  "description": "Essential widget pack for PromptKit — colors, sliders, toggles, animations, and more",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@promptkit/protocol": "0.1.0"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  },
  "license": "MIT"
}
